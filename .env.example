# Cloudflare Pages Function secrets — set these in the Cloudflare Pages
# dashboard (Settings → Environment variables) for production, and in a local
# .env (never committed) for `wrangler pages dev` testing.

# Supabase → Project Settings → API. Server-side only — NEVER expose the
# service-role key to the client or prefix it with VITE_/PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: transactional email notifications on new leads (not used in v1).
RESEND_API_KEY=
